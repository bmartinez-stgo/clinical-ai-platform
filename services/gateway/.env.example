APP_NAME=gateway
APP_NAMESPACE=cap-prod-gateway
APP_ENV=production
APP_PORT=8080
LOG_LEVEL=INFO
SERVICE_VERSION=0.1.0

AUTH_SERVICE_URL=http://auth.cap-prod-auth.svc.cluster.local:8081
REQUEST_TIMEOUT_SECONDS=5
PROXY_CONFIG_PATH=/app/config/routes.yaml

METRICS_ENABLED=true
METRICS_PATH=/metrics

READINESS_CHECK_AUTH=false

TRACING_ENABLED=false
OTEL_SERVICE_NAME=gateway
OTEL_SERVICE_NAMESPACE=cap-prod-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.observability:4318/v1/traces
